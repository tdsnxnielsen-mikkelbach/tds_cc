		isNameInferred
		sourceColumn: [MonthYearSort]

		annotation SummarizationSetBy = Automatic

	partition DateTable = calculated
		mode: import
		source =
				
				ADDCOLUMNS (
				    CALENDAR ( DATE ( 2025, 12, 31 ), DATE ( 2026, 12, 31 ) ),
				    "Year", YEAR ( [Date] ),
				    "Month", MONTH ( [Date] ),
				    "MonthName", FORMAT ( [Date], "MMM" ),
				    "MonthYear", FORMAT ( [Date], "MMM YYYY" ),
				    "MonthYearSort", YEAR ( [Date] ) * 100 + MONTH ( [Date] )
				)

	annotation PBI_Id = d7d371059056400cbc391661e859f508

