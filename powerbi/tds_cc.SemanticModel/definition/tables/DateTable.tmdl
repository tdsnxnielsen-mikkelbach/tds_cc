	column Month
		formatString: 0
		lineageTag: 272230f3-184f-408c-b510-5fc12190c608
		summarizeBy: none
		isNameInferred
		sourceColumn: [Month]

		annotation SummarizationSetBy = Automatic

	column MonthName
		lineageTag: 3e764ca0-71c7-47be-8eba-8ec7efb09063
		summarizeBy: none
		isNameInferred
		sourceColumn: [MonthName]

		annotation SummarizationSetBy = Automatic

	column MonthYear
		lineageTag: bac876c0-78bd-4f2c-b78d-aca9574e884a
		summarizeBy: none
		isNameInferred
		sourceColumn: [MonthYear]
		sortByColumn: MonthYearSort

