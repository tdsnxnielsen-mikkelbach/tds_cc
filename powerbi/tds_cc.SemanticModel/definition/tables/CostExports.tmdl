	partition CostExports = m
		mode: import
		source =
				let
				    StorageAccount = StorageAccountName,
				    Container      = ContainerName,
				    FolderPath     = RootFolderPath,
				
				    Source          = AzureStorage.Blobs("https://" & StorageAccount & ".blob.core.windows.net"),
				    TargetContainer = Source{[Name = Container]}[Data],
				
				    CsvFiles = Table.SelectRows(
				        TargetContainer,
				        each Text.EndsWith([Name], ".csv")
				             and (FolderPath = null or FolderPath = "" or Text.StartsWith([Name], FolderPath & "/"))
				    ),
				
				    ParseCsv = (fileContent as binary) as table =>
				        let
				            Raw      = Csv.Document(fileContent, [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
				            Promoted = Table.PromoteHeaders(Raw, [PromoteAllScalars = true])
				        in
				            Promoted,
				
				    AddedContent   = Table.AddColumn(CsvFiles, "ParsedTable", each ParseCsv([Content])),
				    Combined       = Table.Combine(AddedContent[ParsedTable]),
				
				    CleanedColumns = Table.RemoveColumns(
				        Combined,
				        {"Content", "Name", "Folder Path", "Date accessed", "Date modified", "Date created", "Attributes"},
				        MissingField.Ignore
				    ),
				
				    // Safely parse UsageDate if it exists
				    WithUsageDate = if Table.HasColumns(CleanedColumns, "UsageDate")
				        then Table.TransformColumns(CleanedColumns, {{"UsageDate", each try Date.FromText(_) otherwise null, type date}})
				        else CleanedColumns,
				
				    // Safely parse Date if it exists
				    WithDate = if Table.HasColumns(WithUsageDate, "Date")
				        then Table.TransformColumns(WithUsageDate, {{"Date", each try Date.FromText(_) otherwise null, type date}})
				        else WithUsageDate,
				
				    // Safely cast numeric columns only if they exist
				    WithCost = if Table.HasColumns(WithDate, "PreTaxCost")
				        then Table.TransformColumns(WithDate, {{"PreTaxCost", each try Number.From(_) otherwise null, type number}})
				        else WithDate,
				
				    WithBillingCost = if Table.HasColumns(WithCost, "CostInBillingCurrency")
				        then Table.TransformColumns(WithCost, {{"CostInBillingCurrency", each try Number.From(_) otherwise null, type number}})
				        else WithCost,
				
				    WithCostUSD = if Table.HasColumns(WithBillingCost, "CostInUSD")
				        then Table.TransformColumns(WithBillingCost, {{"CostInUSD", each try Number.From(_) otherwise null, type number}})
				        else WithBillingCost,
				
				    WithCostCol = if Table.HasColumns(WithCostUSD, "Cost")
				        then Table.TransformColumns(WithCostUSD, {{"Cost", each try Number.From(_) otherwise null, type number}})
				        else WithCostUSD,
				
				    WithQuantity = if Table.HasColumns(WithCostCol, "Quantity")
				        then Table.TransformColumns(WithCostCol, {{"Quantity", each try Number.From(_) otherwise null, type number}})
				        else WithCostCol,
				
				    TypedTable = if Table.HasColumns(WithQuantity, "UnitPrice")
				        then Table.TransformColumns(WithQuantity, {{"UnitPrice", each try Number.From(_) otherwise null, type number}})
				        else WithQuantity,
				    #"Changed Type" = Table.TransformColumnTypes(TypedTable,{{"costInBillingCurrency", type number}})
				in
				    #"Changed Type"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

