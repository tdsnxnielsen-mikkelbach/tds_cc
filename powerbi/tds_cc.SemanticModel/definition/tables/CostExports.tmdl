table CostExports
	lineageTag: fa861be7-16b3-4601-9971-d2df8938a856

	measure 'Total Cost' = SUM ( CostExports[costInBillingCurrency] )
		formatString: 0
		lineageTag: cc7f1940-35b2-4105-99c4-c0c68a6e148b

	measure 'Cost MTD' =
			
			VAR _LastDate = MAX ( DateTable[Date] )
			VAR _FirstOfMonth = DATE ( YEAR ( _LastDate ), MONTH ( _LastDate ), 1 )
			RETURN
			CALCULATE ( [Total Cost], DATESBETWEEN ( DateTable[Date], _FirstOfMonth, _LastDate ) )
		formatString: 0
		lineageTag: c0e6ac24-f509-407e-b8f7-b92a0aa63202

	measure 'Cost QTD' = CALCULATE ( [Total Cost], DATESQTD ( DateTable[Date] ) )
		formatString: 0
		lineageTag: 2ae21595-3970-4f50-8df0-09e5a1a8430e

	measure 'Cost YTD' = CALCULATE ( [Total Cost], DATESYTD ( DateTable[Date] ) )
		formatString: 0
		lineageTag: ceedbed1-c3c1-49b7-b06c-a46d9c6973ab

	measure 'Cost Prior Month' =
			
			VAR _MaxDate = MAX ( DateTable[Date] )
			VAR _CurrentMonth = MONTH ( _MaxDate )
			VAR _CurrentYear = YEAR ( _MaxDate )
			VAR _PriorMonth = IF ( _CurrentMonth = 1, 12, _CurrentMonth - 1 )
			VAR _PriorYear = IF ( _CurrentMonth = 1, _CurrentYear - 1, _CurrentYear )
			RETURN
			CALCULATE (
			    [Total Cost],
			    FILTER (
			        ALL ( DateTable ),
			        MONTH ( DateTable[Date] ) = _PriorMonth
			        && YEAR ( DateTable[Date] ) = _PriorYear
			    )
			)
		formatString: 0
		lineageTag: 192d3887-801d-4b94-9cef-231eac1c2afc

	measure 'Cost MoM Change' = [Total Cost] - [Cost Prior Month]
		lineageTag: a38eb17f-7848-4d6b-b1ce-d119db79cf71

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Cost MoM %' =
			
			VAR _Prior = [Cost Prior Month]
			VAR _Current = [Total Cost]
			RETURN
			IF (
			    ISBLANK ( _Prior ) || _Prior = 0,
			    BLANK (),
			    DIVIDE ( _Current - _Prior, _Prior )
			)
		lineageTag: 6a192956-e8c6-41ac-99aa-3bcafe198aac

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Cost Prior Year' = CALCULATE ( [Total Cost], SAMEPERIODLASTYEAR ( DateTable[Date] ) )
		formatString: 0
		lineageTag: 30c0337c-79c3-48a4-8ec6-7bb91a19370e

	measure 'Cost YoY %' = DIVIDE ( [Total Cost] - [Cost Prior Year], [Cost Prior Year] )
		lineageTag: 1fe5930c-ea53-4150-af3a-b7e40b146079

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Daily Cost' = AVERAGEX ( VALUES ( DateTable[Date] ), CALCULATE ( [Total Cost] ) )
		lineageTag: 4e91bc54-9d6b-46ec-a764-d348489c0c24

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Monthly Cost' = AVERAGEX ( VALUES ( DateTable[MonthYear] ), CALCULATE ( [Total Cost] ) )
		lineageTag: 8baab6b1-df82-4f35-b48a-1e88480eb2b2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Cost Month Forecast' = VAR _Days = DAY ( EOMONTH ( TODAY (), 0 ) ) VAR _Day = DAY ( TODAY () ) RETURN IF ( _Day > 0, DIVIDE ( [Cost MTD], _Day ) * _Days )
		lineageTag: 5e5bcc39-1ba6-499d-ae07-cb39d696423b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Top N Cost Share %' = DIVIDE ( [Total Cost], CALCULATE ( [Total Cost], ALL ( CostExports ) ) )
		lineageTag: d0be5e52-5541-4400-a61e-3d994ea01a73

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Cost DKK' = "kr. " & FORMAT ( [Total Cost], "#,##0.00" )
		lineageTag: f8f34d1e-3b07-4456-8669-8854822a157d

	measure 'Total Cost USD' = SUMX ( CostExports, VALUE ( IF ( [costInUsd] = "", "0", [costInUsd] ) ) )
		lineageTag: 2707092d-9e97-4226-8596-04d452574f5b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Exchange Rate' = AVERAGE ( CostExports[exchangeRatePricingToBilling] )
		formatString: 0
		lineageTag: aeb0c60f-d5c2-4b8a-8f8b-3fcf2f889b10

	measure 'Rolling 3M Avg' = AVERAGEX ( DATESINPERIOD ( DateTable[Date], LASTDATE ( DateTable[Date] ), -3, MONTH ), CALCULATE ( [Total Cost] ) )
		lineageTag: 41d8f962-9040-4407-819e-1bcb1a4fb962

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Budget = 1000
		formatString: 0
		lineageTag: 65dc7ac0-4d7c-45e9-bf34-6644ad2eb19d

	measure 'Budget Variance' = [Total Cost] - [Budget]
		lineageTag: 22e36637-454e-4f5d-9247-20899de7e7a3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Budget Variance %' = DIVIDE ( [Budget Variance], [Budget] )
		lineageTag: 0bf41f3d-5e4f-4b73-b878-cf4590e3846f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

